<!DOCTYPE html>
<html lang="ko">
<%- include("header", {title : "게시글 보기"}) %>
<head>
    <meta charset="UTF-8">
    <title><%= post.title %> - 게시글 보기</title>
    <link rel="stylesheet" href="/stylesheets/detail.css">
</head>
<body>

<h2><%= post.title %></h2>
<p><%= post.content %></p>
<p>작성자: <%= post.author %> | 작성일: <%= post.created_at %></p>

<% if (files && files.length > 0) { %>
    <h4>첨부파일</h4>
    <ul>
        <% files.forEach(file => { %>
            <li><a href="/uploads/<%= file.filename %>" download><%= file.filename %></a></li>
        <% }) %>
    </ul>
<% } %>

<%
const isAuthor = user && user.username === post.author;
const isAdmin = user && user.username === 'admin';
const isAnon = post.author === '익명';
%>

<div class="actions">
    <a href="/board/reply/<%= post.id %>">[답글]</a>

    <% if (isAuthor) { %>
        <a href="/board/edit/<%= post.id %>">[수정]</a>
    <% } else { %>
        <span class="disabled">[수정]</span>
    <% } %>

    <% if (isAuthor || (isAnon && isAdmin)) { %>
        <a href="/board/delete/<%= post.id %>" onclick="return confirm('정말 삭제하시겠습니까?')">[삭제]</a>
    <% } else { %>
        <span class="disabled">[삭제]</span>
    <% } %>

    <a href="/board">[목록]</a>
</div>

</body>
<%- include("footer")%>
</html>